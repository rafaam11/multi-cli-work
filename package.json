{
  "name": "multi-cli-work",
  "version": "1.3.0",
  "description": "Project-oriented Windows workspace for Codex, Claude Code, and PowerShell sessions",
  "main": "out/main/index.js",
  "private": true,
  "author": "uiop3847",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "test:e2e": "npm run build && playwright test",
    "dist": "npm run build && electron-builder --win --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "electron-updater": "6.8.9",
    "lucide-react": "1.18.0",
    "node-pty": "1.1.0",
    "proper-lockfile": "4.1.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "3.7.2",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.10.5",
    "@types/proper-lockfile": "4.1.4",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "electron": "34.0.0",
    "electron-builder": "25.1.8",
    "electron-vite": "3.1.0",
    "jsdom": "26.0.0",
    "typescript": "5.7.3",
    "vite": "6.0.11",
    "vitest": "3.2.6"
  },
  "build": {
    "appId": "com.rafaam11.multicliwork",
    "productName": "Multi CLI Work",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**"
    ],
    "artifactName": "Multi-CLI-Work-Setup-${version}.${ext}",
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Multi CLI Work"
    },
    "publish": {
      "provider": "github",
      "owner": "rafaam11",
      "repo": "multi-cli-work"
    }
  }
}
